# ==========================================
# EcclesiaSys - Environment Variables
# ==========================================
# For Render Deployment

# ==========================================
# DATABASE CONFIGURATION (TiDB Cloud)
# ==========================================
DB_URL=jdbc:mysql://[TIDB_HOST]:[TIDB_PORT]/[DATABASE_NAME]?useSSL=true&serverTimezone=UTC
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=[TIDB_USERNAME]
DB_PASSWORD=[TIDB_PASSWORD]

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=benjaminbuckmanjunior@gmail.com
# DO NOT store real passwords in source. Set the real app password in your
# Render/GitHub Actions environment variables instead.
MAIL_PASSWORD=[GMAIL_APP_PASSWORD]
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
PORT=8080
SERVER_PORT=8080
SERVER_SERVLET_SESSION_TIMEOUT=10m
FRONTEND_URL=https://ecclesiasys-bequ.onrender.com
APP_FRONTEND_URL=https://ecclesiasys-bequ.onrender.com
ALLOWED_ORIGINS=https://ecclesiasys-bequ.onrender.com,https://www.ecclesiasys-bequ.onrender.com

# ==========================================
# B2 STORAGE CONFIGURATION
# ==========================================
B2_KEY_ID=[B2_KEY_ID]
B2_APP_KEY=[B2_APP_KEY]
B2_BUCKET_NAME=[B2_BUCKET_NAME]
B2_BUCKET_ID=[B2_BUCKET_ID]

# ==========================================
# SPRING PROFILES
# ==========================================
SPRING_PROFILES_ACTIVE=production

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOGGING_LEVEL_ROOT=WARN
LOGGING_LEVEL_COM_EXAMPLE=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG

# ==========================================
# JPA/HIBERNATE CONFIGURATION
# ==========================================
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update
