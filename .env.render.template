# ==========================================
# EcclesiaSys - Render.com Environment Variables
# ==========================================
# Copy these variables to Render Environment settings
# Replace all [PLACEHOLDER] values with your actual credentials
# DO NOT commit real credentials - use this template only

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# TiDB Cloud MySQL Database
DB_URL=mysql://[TIDB_USERNAME]:[TIDB_PASSWORD]@[TIDB_HOST]:[TIDB_PORT]/[DATABASE_NAME]?useSSL=true&serverTimezone=UTC
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=[TIDB_USERNAME]
DB_PASSWORD=[TIDB_PASSWORD]

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
# These enable password reset emails and other notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=benjaminbuckmanjunior@gmail.com
# NOTE: DO NOT store real passwords in this file. Set the real value
# in your Render or CI environment variables instead of committing it.
MAIL_PASSWORD=[GMAIL_APP_PASSWORD_PLACEHOLDER]
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_SMTP_STARTTLS_REQUIRED=true

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
# Server port (Render assigns this automatically)
PORT=8080
SERVER_PORT=8080

# Session timeout (10 minutes = 600000 milliseconds)
SERVER_SERVLET_SESSION_TIMEOUT=10m

# Frontend URLs (CORS)
FRONTEND_URL=https://yourbbjdigitalapp.onrender.com
ALLOWED_ORIGINS=https://yourbbjdigitalapp.onrender.com,https://www.yourbbjdigitalapp.onrender.com

# ==========================================
# B2 STORAGE CONFIGURATION (If Using Backblaze)
# ==========================================
# Only required if uploading files (sermons, documents, etc.)
B2_KEY_ID=[YOUR_B2_KEY_ID]
B2_APP_KEY=[YOUR_B2_APP_KEY]
B2_BUCKET_NAME=[YOUR_BUCKET_NAME]
B2_BUCKET_ID=[YOUR_BUCKET_ID]

# ==========================================
# SPRING PROFILES
# ==========================================
# Use 'production' profile on Render
SPRING_PROFILES_ACTIVE=production

# ==========================================
# Cloudinary (optional) - set in Render environment
# Format: CLOUDINARY_URL=cloudinary://<API_KEY>:<API_SECRET>@<CLOUD_NAME>
# Example (do NOT commit real keys):
# CLOUDINARY_URL=cloudinary://[CLOUDINARY_API_KEY]:[CLOUDINARY_API_SECRET]@dwny4xblt
# Store the real `CLOUDINARY_URL` in the Render/CI env variables.
# ==========================================

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
# Set logging levels for debugging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG

# ==========================================
# JPA/HIBERNATE CONFIGURATION
# ==========================================
# Database dialect
SPRING_JPA_HIBERNATE_DIALECT=org.hibernate.dialect.MySQL8Dialect
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ==========================================
# PASSWORD RESET SECURITY
# ==========================================
# Frontend password reset URL (update with your actual domain)
PASSWORD_RESET_LINK=https://yourbbjdigitalapp.onrender.com/reset-password?token=

# ==========================================
# SECURITY HEADERS
# ==========================================
SECURITY_ALLOW_CREDENTIALS=true
SECURITY_MAX_AGE=3600

# ==========================================
# DEPLOYMENT NOTES
# ==========================================
# 1. Update all [PLACEHOLDER] fields with actual values
# 2. For Gmail:
#    - Use App Password (not your main password)
#    - Enable "Less secure app access" if 2FA not using app password
#    - Check Gmail "Security" settings
# 3. For TiDB:
#    - Get connection string from TiDB Cloud console
#    - Format: mysql://user:pass@host:port/dbname?useSSL=true
# 4. Update FRONTEND_URL to match your actual Render frontend domain
# 5. Keep this file in .gitignore - never commit real credentials
# 6. Test database connection before deploying
# 7. Test email sending with a test password reset request
