# ========================
# BBJ Digital — Root .gitignore
# ========================

# Local config files with secrets (NEVER commit these)
backend/src/main/resources/config-local.properties
backend/src/main/resources/config-production.properties
backend/src/main/resources/application-production.properties

# Java build output
backend/target/
*.class
*.jar
*.war

# Node modules and build output
frontend/node_modules/
frontend/dist/

# Temp/test files
frontend/serve.py
frontend/out.txt
frontend/vite.log
frontend/build-log.txt
frontend/vite-build-log.txt

# IDE files
.idea/
*.iml
.vscode/
*.DS_Store

# Environment files with secrets (NEVER commit these)
.env
.env.render.template
frontend/.env.local
frontend/.env.production

# Build artifacts and temporary logs
backend/current-compile.txt
backend/mvn-debug.log
compile-output.txt

