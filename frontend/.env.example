# Production Environment Configuration

# API Configuration
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_ENVIRONMENT=development
REACT_APP_FILE_UPLOAD_ENDPOINT=/api/sermons/upload

# Backblaze B2 - Project Key
REACT_APP_B2_KEY_ID=your-b2-key-id-here
REACT_APP_B2_KEY_NAME=Project
REACT_APP_B2_BUCKET_NAME=your-bucket-name

# TiDB Database Connection (for reference, managed by backend)
REACT_APP_DATABASE_URL=mysql://user:password@host:port/database
